FROM node:22-bookworm-slim AS deps
WORKDIR /app
COPY package.json package-lock.json ./
COPY apps/memroos/package.json apps/memroos/package.json
RUN npm ci --workspace apps/memroos --include-workspace-root

FROM node:22-bookworm-slim AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/memroos/node_modules ./apps/memroos/node_modules
COPY package.json package-lock.json ./
COPY apps/memroos apps/memroos
ENV NEXT_TELEMETRY_DISABLED=1
RUN npm --workspace apps/memroos run build

FROM node:22-bookworm-slim AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV npm_config_user_agent="npm/11.12.1 node/v22 linux x64 workspaces/false"
COPY --from=builder /app/package.json /app/package-lock.json ./
COPY --from=builder /app/apps/memroos/package.json ./apps/memroos/package.json
COPY --from=builder /app/apps/memroos/.next ./apps/memroos/.next
COPY --from=builder /app/apps/memroos/public ./apps/memroos/public
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/memroos/node_modules ./apps/memroos/node_modules
EXPOSE 3000
CMD ["npm", "--workspace", "apps/memroos", "run", "start", "--", "--hostname", "0.0.0.0", "--port", "3000"]
