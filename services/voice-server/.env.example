# API Keys (required for respective modes)
GOOGLE_API_KEY=        # Gemini Live mode (VOICE-02)
GROQ_API_KEY=          # Cascade STT (VOICE-03) — if absent, falls back to WhisperSTTServiceMLX (local)
CARTESIA_API_KEY=      # Primary TTS (VOICE-03)
ELEVENLABS_API_KEY=    # TTS fallback (VOICE-03)
GRADIUM_API_KEY=       # Optional TTS fallback (VOICE-03) — inserted between ElevenLabs and Kokoro

# Voice mode: "gemini" or "cascade"
VOICE_MODE=gemini

# CRITICAL: Must be ABSOLUTE path — Python and Next.js have different cwd.
# Relative paths like "data/conversations.db" resolve differently depending on
# which directory each process is started from, creating two separate DB files.
SQLITE_DB_PATH=/Users/yourname/github/agent-kitchen/data/conversations.db

# Voice agent LLM model (cascade mode only)
VOICE_AGENT_MODEL=claude-opus-4-5
