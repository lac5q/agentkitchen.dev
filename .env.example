# MemroOS — Environment Configuration
# Copy this to .env.local and update paths for your system

# ── Knowledge Base ──────────────────────────────────────────────────────────
# Path to your knowledge repository (QMD collections)
KNOWLEDGE_BASE_PATH=/Users/yourname/github/knowledge

# ── Agent Configs ────────────────────────────────────────────────────────────
# Path to agent config directories (each subfolder = one agent)
AGENT_CONFIGS_PATH=/Users/yourname/github/knowledge/agent-configs

# ── Memory ───────────────────────────────────────────────────────────────────
# Path to Claude Code projects directory (auto-memory files)
CLAUDE_MEMORY_PATH=/Users/yourname/.claude/projects

# mem0 semantic memory API
MEM0_URL=http://localhost:3201
MEM0_PORT=3201

# Unified memory tiers (Phase 37): vector=mem0/Qdrant Cloud, graph=mem0/Neo4j,
# episodic=Memroos SQLite. Qdrant remains cloud-only and is configured by mem0.
QDRANT_URL=https://your-qdrant-cloud-endpoint
QDRANT_API_KEY=your-qdrant-cloud-api-key
NEO4J_HTTP_URL=http://localhost:7474
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_DATABASE=neo4j
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me

# Local mem0 model service
# Ollama must have qwen2.5:3b and nomic-embed-text pulled locally.
OLLAMA_BASE_URL=http://localhost:11434

# Memory resilience monitors. macOS setup installs launchd monitors by default.
# Set INSTALL_MEMORY_RESILIENCE=0 to skip. Configure one remote alert sink if
# you want off-machine notifications; otherwise local macOS notifications are used.
INSTALL_MEMORY_RESILIENCE=1
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_KNOWLEDGE_WEBHOOK=

# ── APO (Agent Lightning) ────────────────────────────────────────────────────
# Path to APO proposal files
APO_PROPOSALS_PATH=/Users/yourname/.openclaw/skills/proposals

# Path to Agent Lightning cron log
APO_CRON_LOG_PATH=/Users/yourname/.openclaw/logs/agent-lightning-cron.log

# ── Remote Agents ─────────────────────────────────────────────────────────────
# Remote agents are configured in agents.config.json (no env vars needed)
# To add agents, edit agents.config.json

# ── Operator Registry Writes ─────────────────────────────────────────────────
# Required for registry registration/deregistration when Memroos is not accessed
# through localhost. Leave unset for local-dev loopback-only registration.
# MEMROOS_OPERATOR_API_KEY=change-me

# ── A2A Hub (Phase 35) ──────────────────────────────────────────────────────
# local-dev | single-host | private-network | cloud-https | custom
MEMROOS_A2A_PROFILE=local-dev
MEMROOS_PORT=3000
MEMROOS_PUBLIC_BASE_URL=http://localhost:3000
MEMROOS_A2A_ENDPOINT_BASE_URL=http://localhost:3000
MEMROOS_A2A_REMOTE_CARD_TIMEOUT_MS=5000
MEMROOS_A2A_ALLOW_PRIVATE_NETWORK_CARDS=true
MEMROOS_A2A_ADK_FIXTURE_CARD_URL=http://localhost:8001/a2a/check_prime_agent/.well-known/agent-card.json

# ── LangGraph Orchestration (Phase 36) ──────────────────────────────────────
ORCHESTRATION_SERVICE_URL=http://localhost:3210
ORCHESTRATION_PORT=3210
ORCHESTRATION_DB_PATH=data/orchestration.db
ORCHESTRATION_RETRY_LIMIT=2

# ── Optional: Override config file paths ────────────────────────────────────
# AGENTS_CONFIG_PATH=./agents.config.json
# COLLECTIONS_CONFIG_PATH=./collections.config.json
CONTEXT_SOURCES_CONFIG=./context-sources.config.json

# ── Public Web Analytics ─────────────────────────────────────────────────────
# Google Analytics 4 measurement ID for the public Next.js app.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ── Context Source Contracts (Phase 69) ─────────────────────────────────────
GMAIL_INGEST_ENABLED=0
SPARK_TRANSCRIPTS_DB=
LOCAL_CONTEXT_PATH=./docs

# ── Public Eval API (Phase 62) ───────────────────────────────────────────────
# URL used by the internal SDK client for dogfood calls (SEAL/autogen loop).
MEMROOS_PUBLIC_API_URL=http://localhost:3000
# Pre-seeded API key for internal dogfood calls. Value: "memroos-internal-default-key"
# Generate a custom key with: npx ts-node apps/memroos/scripts/generate-api-key.ts
MEMROOS_INTERNAL_API_KEY=memroos-internal-default-key

# ── Self-hosted Compliance / Data Residency (Phase 66) ──────────────────────
# When enabled, judge/model calls must use a configured local endpoint.
MEMROOS_DATA_RESIDENCY=0
LOCAL_JUDGE_PROVIDER=ollama
LOCAL_JUDGE_ENDPOINT=http://localhost:11434/v1
LOCAL_JUDGE_MODEL=hermes3
AUDIT_RETENTION_DAYS=365

# ── Team Auth (Phase 63) ─────────────────────────────────────────────────────
# HS256 secret for JWT access tokens — generate with: openssl rand -base64 32
MEMROOS_JWT_SECRET=change-me-to-a-random-32-char-string
# First-run admin seed: if no users exist, create admin with these credentials
MEMROOS_ADMIN_EMAIL=admin@example.com
MEMROOS_ADMIN_PASSWORD=change-me-strong-password
# Base URL used for invite link generation (defaults to request Host header)
# MEMROOS_BASE_URL=https://your-domain.com
# Set only when a trusted platform/proxy overwrites client IP headers.
AUTH_TRUST_PROXY_HEADERS=0

# ── Optional Progressive Capabilities ────────────────────────────────────────
# Comma-separated opt-in checks for bundled-but-optional capabilities.
# Supported: gitnexus, agent-lightning
MEMROOS_OPTIONAL_CAPABILITIES=

# GitNexus code graph registry
GITNEXUS_REGISTRY=/Users/yourname/.gitnexus/registry.json

# ── Memory Intelligence (Phase 23) ───────────────────────────────────────────
# Anthropic API key for LLM consolidation engine (MEM-01)
ANTHROPIC_API_KEY=your-key-here

# Model used for memory consolidation (insight extraction).
# Default: claude-haiku-4-5-20251001 (cheapest Anthropic option).
# Must be an Anthropic model ID — Gemini/Minimax not yet supported.
CONSOLIDATION_MODEL=claude-haiku-4-5-20251001

# ── Voice / Gemini ───────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-key-here
VOICE_MODE=gemini
VOICE_WS_PORT=7860
VOICE_HEALTH_PORT=7861

# ── Multi-source ingest paths (Phase 23) ─────────────────────────────────────
# Override default session storage paths if yours differ
QWEN_MEMORY_PATH=/Users/yourname/.qwen/projects
HERMES_MEMORY_PATH=/Users/yourname/.hermes/sessions
CODEX_MEMORY_PATH=/Users/yourname/.codex/sessions
